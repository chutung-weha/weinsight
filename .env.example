# Database (Supabase PostgreSQL)
#
# LƯU Ý:
# - Nếu password chứa ký tự đặc biệt như @, :, /, ?, # thì phải URL-encode trước khi đưa vào URL
#   Ví dụ: Weinsight@123 -> Weinsight%40123
# - DATABASE_URL dùng pooler
# - DIRECT_URL dùng direct database endpoint
DATABASE_URL="postgresql://postgres.[project-ref]:[url-encoded-password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:[url-encoded-password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_SECRET=""  # Generate: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"  # Production: https://your-domain.com

# Google OAuth
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (Groq — free tier: 14.400 req/ngày)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=""
